{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "mkdir -p _site && printf '<!doctype html><title>Moved</title><meta http-equiv=refresh content=0;url=https://mijudrama.com/>Moved to https://mijudrama.com/' > _site/index.html",
  "outputDirectory": "_site",
  "redirects": [
    { "source": "/tv/:path*", "destination": "https://mijudrama.com/drama", "permanent": true },
    { "source": "/drama/:path*", "destination": "https://mijudrama.com/drama", "permanent": true },
    { "source": "/movie/:path*", "destination": "https://mijudrama.com/movie", "permanent": true },
    { "source": "/person/:path*", "destination": "https://mijudrama.com/people", "permanent": true },
    { "source": "/people/:path*", "destination": "https://mijudrama.com/people", "permanent": true },
    { "source": "/lists/:path*", "destination": "https://mijudrama.com/lists", "permanent": true },
    { "source": "/search/:path*", "destination": "https://mijudrama.com/search", "permanent": true },
    { "source": "/:path*", "destination": "https://mijudrama.com/", "permanent": true }
  ]
}
